# Frontend → backend connection.
# Base URL of the deployed API (no trailing slash).
#   Local dev (default if unset): http://localhost:8000
#   Production (Vercel): your Render URL, e.g. https://vayunetra-api.onrender.com
# On Vercel, add this as an Environment Variable named NEXT_PUBLIC_API_BASE
# (read at build time — set it BEFORE deploying, or redeploy after adding it).
NEXT_PUBLIC_API_BASE=https://vayunetra-api.onrender.com

# OPTIONAL — premium vector basemaps (MapTiler: Dark Matter / Streets / Satellite-Hybrid).
# Get a free key at https://www.maptiler.com/ (free tier ~100k loads/month).
# If unset, the map uses detailed keyless raster tiles (CARTO + Esri satellite) — still works,
# just not vector. Add this in Vercel as NEXT_PUBLIC_MAPTILER_KEY, then redeploy.
NEXT_PUBLIC_MAPTILER_KEY=
