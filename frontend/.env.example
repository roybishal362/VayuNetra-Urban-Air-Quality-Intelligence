# Frontend → backend connection.
# The base URL of the deployed API (no trailing slash).
#   Local dev (default if unset): http://localhost:8000
#   Production (Vercel): set this to your Render URL, e.g.
#   https://vayunetra-api.onrender.com
#
# On Vercel, add this as an Environment Variable named NEXT_PUBLIC_API_BASE.
# It is read at build time, so set it BEFORE deploying (or redeploy after adding it).
NEXT_PUBLIC_API_BASE=https://vayunetra-api.onrender.com
