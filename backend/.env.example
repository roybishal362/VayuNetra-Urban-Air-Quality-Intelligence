# VayuNetra backend configuration.
# IMPORTANT: every key below is OPTIONAL. With no keys set, the system runs fully
# on curated offline snapshots + a deterministic template generator. Nothing crashes.

# Enables live LLM-written citizen advisories + enforcement briefs (else templated fallback).
ANTHROPIC_API_KEY=

# Enables live ground-station pulls from OpenAQ v3 (else cached snapshot).
OPENAQ_API_KEY=

# Enables live NASA FIRMS active-fire pulls (else cached snapshot).
FIRMS_MAP_KEY=

# dev | prod
ENVIRONMENT=dev
