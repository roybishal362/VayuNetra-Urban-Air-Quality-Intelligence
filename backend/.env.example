# VayuNetra backend configuration.
# Every key below is OPTIONAL. With nothing set the platform runs on offline snapshots +
# deterministic templates and never crashes. Add keys to "go fully live".

# ---- LLM (primary: Groq — OpenAI-compatible, fast + low-cost) ----
# Free key: https://console.groq.com/keys
GROQ_API_KEY=
# Strong default. Alternatives: openai/gpt-oss-120b, qwen/qwen3-32b, moonshotai/kimi-k2-instruct
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Optional Anthropic fallback (used only if GROQ_API_KEY is empty) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Real active fires (else a seasonal model is used, flagged honestly) ----
# Free key: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# ---- Real ground stations overlay (else CAMS only) ----
# Free key: https://openaq.org
OPENAQ_API_KEY=

ENVIRONMENT=dev
